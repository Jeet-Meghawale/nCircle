// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Defining eNum
enum Role {
  ADMIN
  COORDINATOR
  STUDENT
}

enum ApplicationStatus {
  PENDING_COORDINATOR
  PENDING_ADMIN
  APPROVED
  REJECTED
  CANCELLED
}

enum ProjectVisibility {
  LISTED
  UNLISTED
}

enum MemberRole {
  LEADER
  MEMBER
}

enum WorkspaceRole {
  LEADER
  MEMBER
  COORDINATOR
  ADMIN
}

model User {
  id String @id @default(uuid())

  firstName String
  lastName  String

  email    String @unique
  password String

  mobile String?

  role Role @default(STUDENT)

  college        String?
  branch         String?
  graduationYear Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  /**
   * ---------------------------------
   * Project System Relations
   * ---------------------------------
   */

  createdProjects Project[] @relation("ProjectCreator")

  ledApplications ProjectApplication[] @relation("ApplicationLeader")

  coordApplication ProjectApplication[] @relation("ApplicationCoordinator")

  approvedApplications ProjectApplication[] @relation("ApplicationApprover")

  applicationMemberships ApplicationMember[]

  coordinatedGroups Group[] @relation("GroupCoordinator")

  groupMemberships GroupMember[]

  workspaceMemberships WorkspaceMember[]

  @@index([role])
}

model RefreshToken {
  id    String @id @default(uuid())
  token String @unique

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  revoked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Project {
  id          String @id @default(uuid())
  title       String
  description String

  createdBy String
  creator   User   @relation("ProjectCreator", fields: [createdBy], references: [id])

  visibility ProjectVisibility @default(LISTED)
  isActive   Boolean           @default(true)

  statusRemark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications ProjectApplication[]
  groups       Group[]

  @@index([createdBy])
}

model ProjectApplication {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  leaderId String
  leader   User   @relation("ApplicationLeader", fields: [leaderId], references: [id])

  coordinatorId String
  coordinator User @relation("ApplicationCoordinator",fields: [coordinatorId],references: [id])

  status ApplicationStatus @default(PENDING_COORDINATOR)
  isApproved Boolean @default(false)

  approvedById String?
  approvedBy   User?   @relation("ApplicationApprover", fields: [approvedById], references: [id])

  verifiedAt DateTime?
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members ApplicationMember[]

  group Group?

  @@unique([projectId, leaderId])
  @@index([projectId])
  @@index([leaderId])
  @@index([status])
}

model ApplicationMember {
  id String @id @default(uuid())

  applicationId String
  application   ProjectApplication @relation(fields: [applicationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  role MemberRole

  createdAt DateTime @default(now())

  @@unique([applicationId, userId])
}

model Group {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  applicationId String             @unique
  application   ProjectApplication @relation(fields: [applicationId], references: [id])

  coordinatorId String
  coordinator   User   @relation("GroupCoordinator", fields: [coordinatorId], references: [id])

  createdAt DateTime @default(now())

  members   GroupMember[]
  workspace Workspace?

  @@index([projectId])
  @@index([coordinatorId])
}

model GroupMember {
  id String @id @default(uuid())

  groupId String
  group   Group  @relation(fields: [groupId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  role MemberRole

  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
}

model Workspace {
  id String @id @default(uuid())

  groupId String @unique
  group   Group  @relation(fields: [groupId], references: [id])

  createdAt DateTime @default(now())

  members WorkspaceMember[]
}

model WorkspaceMember {
  id String @id @default(uuid())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  role WorkspaceRole

  joinedAt DateTime @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}